<%= form_with model: [:organizador, quiz], local: true do |f| %>
  <% if quiz.errors.any? %>
    <div class="alert alert-danger">
      <strong>Não foi possível salvar:</strong>
      <ul class="mb-0">
        <% quiz.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :titulo, class: "form-label" %>
    <%= f.text_field :titulo, class: "form-control", required: true %>
  </div>

  <fieldset class="mb-3">
    <legend class="h6">Identificação do participante</legend>
    <p class="text-muted small">
      Nome é sempre obrigatório. Configure abaixo se email e telefone serão pedidos.
    </p>

    <div class="row">
      <div class="col-md-6 mb-3">
        <%= f.label :email_state, "Email", class: "form-label" %>
        <%= f.select :email_state,
              [["Não pedir", "not_asked"], ["Opcional", "optional"], ["Obrigatório", "required"]],
              {}, class: "form-select" %>
      </div>
      <div class="col-md-6 mb-3">
        <%= f.label :phone_state, "Telefone", class: "form-label" %>
        <%= f.select :phone_state,
              [["Não pedir", "not_asked"], ["Opcional", "optional"], ["Obrigatório", "required"]],
              {}, class: "form-select" %>
      </div>
    </div>
  </fieldset>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancelar", organizador_quizzes_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
