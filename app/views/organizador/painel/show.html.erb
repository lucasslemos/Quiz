<% content_for :title, "Painel — Quiz" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Olá, <%= current_organizador.email %></h1>
  <%= link_to "Novo quiz", new_organizador_quiz_path, class: "btn btn-primary" %>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="h5 mb-0">Quizzes recentes</h2>
          <%= link_to "Ver todos", organizador_quizzes_path, class: "small" %>
        </div>
        <% if @quizzes_recentes.any? %>
          <ul class="list-group list-group-flush">
            <% @quizzes_recentes.each do |quiz| %>
              <li class="list-group-item px-0">
                <%= link_to quiz.titulo, organizador_quiz_path(quiz) %>
                <small class="text-muted d-block">
                  <%= pluralize(quiz.perguntas.size, "pergunta") %> ·
                  <%= pluralize(quiz.campanhas.size, "campanha") %>
                </small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small mb-0">Você ainda não criou nenhum quiz.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-body">
        <h2 class="h5 mb-3">Campanhas ativas</h2>
        <% if @campanhas_ativas.any? %>
          <ul class="list-group list-group-flush">
            <% @campanhas_ativas.each do |campanha| %>
              <li class="list-group-item px-0">
                <%= link_to campanha.nome, organizador_quiz_campanha_path(campanha.quiz, campanha) %>
                <small class="text-muted d-block">
                  <%= campanha.quiz.titulo %> · /c/<%= campanha.slug %>
                </small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small mb-0">Nenhuma campanha ativa no momento.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
