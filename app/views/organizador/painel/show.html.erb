<% content_for :title, "Painel — Quiz" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Olá, <%= current_organizador.email %></h1>
  <%= button_to "Sair", sair_path, method: :delete, class: "btn btn-sm btn-outline-secondary" %>
</div>

<div class="card">
  <div class="card-body">
    <p class="mb-2">
      Você está aprovado e pode criar quizzes e campanhas.
    </p>
    <p class="text-muted small mb-0">
      As funcionalidades de gestão de quizzes serão adicionadas nos próximos grupos do <code>booth-quiz-mvp</code>.
    </p>
  </div>
</div>
