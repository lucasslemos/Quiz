<% content_for :title, @campanha.nome %>

<h1 class="h4 mb-3"><%= @campanha.nome %></h1>
<p class="text-muted">Preencha seus dados para começar.</p>

<%= form_with url: publico_campanha_iniciar_path(@campanha.slug), scope: :participacao, local: true do |f| %>
  <% if @participacao&.errors&.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @participacao.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :nome, class: "form-label" %>
    <%= f.text_field :nome, class: "form-control", required: true %>
  </div>

  <% if @quiz.email_state != "not_asked" %>
    <div class="mb-3">
      <%= f.label :email, "E-mail", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: @quiz.email_state == "required" %>
    </div>
  <% end %>

  <% if @quiz.phone_state != "not_asked" %>
    <div class="mb-3">
      <%= f.label :telefone, "Telefone", class: "form-label" %>
      <%= f.telephone_field :telefone, class: "form-control", required: @quiz.phone_state == "required" %>
    </div>
  <% end %>

  <% @campos_personalizados.each do |campo| %>
    <div class="mb-3">
      <%= label_tag "participacao[campos_personalizados][#{campo.id}]", campo.rotulo, class: "form-label" %>
      <% case campo.tipo_campo %>
      <% when "select" %>
        <%= select_tag "participacao[campos_personalizados][#{campo.id}]",
              options_for_select((campo.opcoes || []).map { |o| [o, o] }),
              class: "form-select", include_blank: true, required: campo.obrigatorio %>
      <% when "email" %>
        <%= email_field_tag "participacao[campos_personalizados][#{campo.id}]", nil, class: "form-control", required: campo.obrigatorio %>
      <% when "phone" %>
        <%= telephone_field_tag "participacao[campos_personalizados][#{campo.id}]", nil, class: "form-control", required: campo.obrigatorio %>
      <% else %>
        <%= text_field_tag "participacao[campos_personalizados][#{campo.id}]", nil, class: "form-control", required: campo.obrigatorio %>
      <% end %>
    </div>
  <% end %>

  <%= f.submit "Começar", class: "btn btn-primary w-100" %>
<% end %>
