<% content_for :title, "Entrar — Quiz" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <h1 class="h3 mb-4">Entrar</h1>

    <%= form_with url: entrar_path, method: :post, local: true do |f| %>
      <div class="mb-3">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true, autofocus: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true %>
      </div>

      <div class="d-flex justify-content-between align-items-center">
        <%= f.submit "Entrar", class: "btn btn-primary" %>
        <%= link_to "Esqueci minha senha", nova_senha_path, class: "small" %>
      </div>
    <% end %>

    <hr class="my-4">

    <p class="text-center">
      Ainda não tem conta? <%= link_to "Cadastre-se", cadastro_path %>.
    </p>
  </div>
</div>
