<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Quiz" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Quiz">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Bootstrap 5 empacotado pelo cssbundling-rails (entrada: application.bootstrap.scss) %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
      <div class="container">
        <% if defined?(current_organizador) && current_organizador&.aprovado? %>
          <%= link_to "Quiz", organizador_root_path, class: "navbar-brand fw-bold" %>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#orgNav">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="orgNav">
            <ul class="navbar-nav me-auto">
              <li class="nav-item">
                <%= link_to "Painel", organizador_root_path,
                      class: "nav-link #{'active' if controller_name == 'painel'}" %>
              </li>
              <li class="nav-item">
                <%= link_to "Meus quizzes", organizador_quizzes_path,
                      class: "nav-link #{'active' if controller_name == 'quizzes' || controller_name == 'perguntas' || controller_name == 'campos_personalizados'}" %>
              </li>
            </ul>
            <span class="navbar-text me-3 small text-muted"><%= current_organizador.email %></span>
            <%= button_to "Sair", sair_path, method: :delete, class: "btn btn-sm btn-outline-secondary" %>
          </div>
        <% else %>
          <%= link_to "Quiz", root_path, class: "navbar-brand fw-bold" %>
          <div class="ms-auto d-flex gap-2">
            <%= link_to "Entrar", entrar_path, class: "btn btn-sm btn-outline-primary" %>
            <%= link_to "Cadastro", cadastro_path, class: "btn btn-sm btn-primary" %>
          </div>
        <% end %>
      </div>
    </nav>

    <main class="container py-4">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == "notice" ? "success" : "warning" %>"><%= message %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
