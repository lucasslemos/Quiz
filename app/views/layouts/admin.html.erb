<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Admin · Quiz" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
      <div class="container">
        <%= link_to "Quiz · Admin", admin_organizadores_path, class: "navbar-brand fw-bold" %>
        <% if defined?(current_administrador) && current_administrador %>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="adminNav">
            <ul class="navbar-nav me-auto">
              <li class="nav-item">
                <%= link_to "Todos organizadores", admin_organizadores_path,
                      class: "nav-link #{'active' if controller_name == 'organizadores' && action_name == 'index'}" %>
              </li>
              <li class="nav-item">
                <%= link_to "Pendentes", pendentes_admin_organizadores_path,
                      class: "nav-link #{'active' if controller_name == 'organizadores' && action_name == 'pendentes'}" %>
              </li>
            </ul>
            <span class="navbar-text text-light me-3 small"><%= current_administrador.email %></span>
            <%= button_to "Sair", admin_sair_path, method: :delete, class: "btn btn-sm btn-outline-light" %>
          </div>
        <% end %>
      </div>
    </nav>

    <main class="container py-4">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == "notice" ? "info" : "danger" %>"><%= message %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
